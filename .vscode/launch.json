{
  "version": "0.2.0",
  "configurations": [
    
    // =========================
    // 🟦 React Frontend Debug
    // =========================
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "React Frontend (Chrome)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend/src"
    },

    // =========================
    // 🟩 Go Backend Debug
    // =========================
    {
      "name": "Go Backend API",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "8002"
      }
    }
  ],

  // =========================
  // 🚀 Optional: Run both together
  // =========================
  "compounds": [
    {
      "name": "Full Stack Debug (React + Go)",
      "configurations": [
        "React Frontend (Chrome)",
        "Go Backend API"
      ]
    }
  ]
}